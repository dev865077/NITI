project Lightning_Cdlc_Proofs is
   for Source_Dirs use ("src");
   for Source_Files use
     ("lightning_cdlc_algebra.ads", "lightning_cdlc_algebra.adb");
   for Object_Dir use "obj";
   for Main use ();
   package Compiler is
      for Switches ("Ada") use ("-gnata", "-gnat2022");
   end Compiler;
end Lightning_Cdlc_Proofs;
