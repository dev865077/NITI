BITCOIN_RPC_URL=http://127.0.0.1:18332
BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=

# Optional when using Bitcoin Core wallet RPC:
# BITCOIN_RPC_WALLET=niti-testnet

# Deterministic regtest helper:
# scripts/regtest-env.sh start
# scripts/regtest-env.sh env > .env

# Recommended networks for this harness:
# - testnet4
# - signet
# - testnet

# Lightning cDLC hold-invoice harness.
# Use separate LND nodes for payer and receiver in regtest/signet/testnet.
# Mutating LND commands require --allow-live-lnd.
LND_NETWORK=regtest

# Receiver node: creates and settles the hold invoice.
LND_RECEIVER_URL=https://127.0.0.1:8081
LND_RECEIVER_MACAROON_PATH=
LND_RECEIVER_MACAROON_HEX=
LND_RECEIVER_TLS_CERT_PATH=
LND_RECEIVER_ALLOW_INSECURE_TLS=false

# Payer node: pays the receiver's hold invoice.
LND_PAYER_URL=https://127.0.0.1:8082
LND_PAYER_MACAROON_PATH=
LND_PAYER_MACAROON_HEX=
LND_PAYER_TLS_CERT_PATH=
LND_PAYER_ALLOW_INSECURE_TLS=false
